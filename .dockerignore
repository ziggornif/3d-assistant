# Git
.git
.gitignore

# Rust build artifacts
target/
.cargo/

# Node modules
node_modules/

# Data and uploads (runtime data)
data/
uploads/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

