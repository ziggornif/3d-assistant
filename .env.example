# Database Configuration
DATABASE_URL=sqlite://./data/quotes.db
# For PostgreSQL: DATABASE_URL=postgres://user:password@localhost/quote_service

# Server Configuration
HOST=127.0.0.1
PORT=3000

# Environment
RUST_LOG=info
ENVIRONMENT=development

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Session Configuration
SESSION_EXPIRY_HOURS=24
