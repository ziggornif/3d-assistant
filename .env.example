# Database Configuration (PostgreSQL)
DATABASE_URL=postgres://quote_service:quote_secret_2025@localhost:5432/quotes

# Server Configuration
HOST=127.0.0.1
PORT=3000

# Environment
RUST_LOG=info
ENVIRONMENT=development

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Session Configuration
SESSION_EXPIRY_HOURS=24

# Admin Token (CRITICAL: Change in production!)
ADMIN_TOKEN=admin-secret-token-2025

# MCP Token (Model Context Protocol authentication)
MCP_TOKEN=mcp-token-placeholder

# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=quote-service

# Static and Template Directories
STATIC_DIR=./static
TEMPLATE_DIR=./templates
